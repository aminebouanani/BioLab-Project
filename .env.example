# Use a randomly generated secret of at least 32 characters.
GLIMS_HMAC_SECRET=

# Paths are relative to the repository root unless absolute.
SYNTHEA_ZIP_DIR=data/raw/synthea_zips
SYNTHEA_EXTRACTION_DIR=data/extracted/synthea
GLIMS_OUTPUT_PATH=data/bronze/glims_lab_results.jsonl
LOG_LEVEL=INFO

# Kafka/Redpanda local streaming is disabled by default.
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Local PySpark medallion pipeline paths.
SPARK_MASTER=local[*]
HADOOP_HOME=hadoop
DATA_LAKE_ROOT=data
BRONZE_PATH=data/bronze/glims_events
SILVER_PATH=data/silver/lab_results
GOLD_REPORT_CONTEXT_PATH=data/gold/report_context
GOLD_DASHBOARD_KPIS_PATH=data/gold/dashboard_kpis

# Local AI backend.
AI_BACKEND_DATABASE_URL=sqlite:///app_state/biolab_local.db
AI_PROVIDER=mock_medgemma
